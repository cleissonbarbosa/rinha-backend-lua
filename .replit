modules = ["lua", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["openresty", "redis", "nginx"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Payment Backend"

[[workflows.workflow]]
name = "Payment Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./run-payment-gateway.sh"
waitForPort = 9999

[[ports]]
localPort = 6379
externalPort = 3000

[[ports]]
localPort = 8001
externalPort = 3002

[[ports]]
localPort = 8002
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 9999
externalPort = 3001
